# Data artifacts (ADR-003 data folder conventions)
# - data/raw/ is corpora — reproducible from canonical source
# - data/indexes/ is build output — deterministic from code + config + raw corpus
# - data/eval/ IS checked in (query set + graded relevance are authored artifacts)
/data/raw/*
!/data/raw/.gitkeep
!/data/raw/bcbooks/
/data/indexes/*
!/data/indexes/.gitkeep
/data/logs/*
!/data/logs/.gitkeep

.scripvec_config.json
